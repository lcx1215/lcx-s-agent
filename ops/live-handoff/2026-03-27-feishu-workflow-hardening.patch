+  const sessionKey = content.match(/- \*\*Current Session Key\*\*: ([^\n]+)/)?.[1]?.trim();
+  const turnCount = content
+    .match(/## Recent Turns\n([\s\S]*)$/)?.[1]
+    ?.split(/\n(?=### )/u)
+    .map((entry) => entry.trim())
+    .filter(Boolean).length;
+  if (!surface || !chat || !laneKey || !lastUpdated || !sessionKey) {
+    return undefined;
+  }
+  return {
+    surface,
+    chat,
+    laneKey,
+    lastUpdated,
+    sessionKey,
+    turnCount: turnCount ?? 0,
+  };
+}
