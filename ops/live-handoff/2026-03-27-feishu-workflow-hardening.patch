+  const correctionNotes = parseWorkfaceMetric(params.content, "Correction Notes") ?? "0";
+  const watchtowerSignals = parseWorkfaceMetric(params.content, "Watchtower Signals") ?? "0";
+  const portfolioScorecard = parseWorkfaceMetric(params.content, "Portfolio Scorecard");
+  const totalTokens = parseWorkfaceMetric(params.content, "Total Tokens") ?? "0";
+  const estimatedCost = parseWorkfaceMetric(params.content, "Estimated Cost") ?? "$0.0000";
+  const weakestDomain =
+    params.content.match(/- Weakest Domain: ([^\n]+)/)?.[1]?.trim() ??
+    params.content.match(/## Weakest Domains\n- ([^\n]+)/)?.[1]?.trim();
+  const hallucinationWatch =
+    params.content.match(/- Hallucination Watch: ([^\n]+)/)?.[1]?.trim() ??
+    params.content.match(/## Hallucination-Prone Domains\n- ([^\n]+)/)?.[1]?.trim();
+  const lanePanel = parseWorkfaceLanePanelSummary(params.content);
+  const scorecardPart = portfolioScorecard ? `, scorecard ${portfolioScorecard}` : "";
+  const validationPart = weakestDomain ? `, weakest ${weakestDomain}` : "";
+  const riskPart = hallucinationWatch ? `, hallucination watch ${hallucinationWatch}` : "";
+  const lanePart = lanePanel ? `, ${lanePanel}` : "";
+  return `Workface (${date}): learned ${learningItems}, corrected ${correctionNotes}, watchtower ${watchtowerSignals}${scorecardPart}${validationPart}${riskPart}${lanePart}, tokens ${totalTokens}, estimated cost ${estimatedCost}.`;
