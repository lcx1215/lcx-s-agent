+function parseWorkfaceLanePanelSummary(content: string): string | undefined {
+  const activeLanes = parseWorkfaceMetric(content, "Active Surface Lanes");
+  const laneBlock = content.match(/## Feishu Lane Panel\n([\s\S]*?)(?:\n## |\n?$)/)?.[1] ?? "";
+  const laneRows = laneBlock
+    .split("\n")
+    .map((line) => line.trim())
+    .filter((line) => line.startsWith("- "))
+    .filter((line) => !/^- Active Lanes:/i.test(line))
+    .slice(0, 2)
+    .map((line) =>
+      line
+        .replace(/^- /, "")
+        .replace(/\s*·\s*session[\s\S]*$/u, "")
+        .trim(),
+    );
+
+  if (!activeLanes && laneRows.length === 0) {
+    return undefined;
+  }
+
+  const parts = [
+    activeLanes ? `${activeLanes} active lane${activeLanes === "1" ? "" : "s"}` : undefined,
+  ];
+  if (laneRows.length > 0) {
+    parts.push(`meter ${laneRows.join("; ")}`);
+  }
+  return `lane panel ${parts.filter(Boolean).join(", ")}`;
+}
